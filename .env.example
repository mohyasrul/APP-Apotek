# MediSir POS — Environment Variables
# Salin file ini menjadi .env.local dan isi dengan nilai yang sesuai.
# JANGAN commit file .env.local ke version control (sudah di .gitignore).

# ─── Supabase ─────────────────────────────────────────────────
# Dapatkan dari: Supabase Dashboard → Project Settings → API

# URL project Supabase Anda (wajib)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Anon/public key — aman diekspos di frontend karena dilindungi RLS (wajib)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Sentry (opsional) ──────────────────────────────────────────
# Error monitoring — aktif hanya di production jika DSN di-set.
# Dapatkan dari: sentry.io → Project → Settings → Client Keys (DSN)
# Biarkan kosong / hapus baris ini jika tidak menggunakan Sentry.
VITE_SENTRY_DSN=
